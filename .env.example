# Frontend Environment Variables
# Copy this file to .env and fill in the values

# API URL for leaderboard (optional, defaults to /api/leaderboard)
# Use this for local development with a different backend
VITE_API_URL=

# ===========================================
# The following are provided by Netlify automatically
# Do NOT add these to .env - they are injected at runtime
# ===========================================
# NETLIFY_BLOBS_CONTEXT - Blob storage credentials (auto-provided by Netlify)
